{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": false },
  "files": {
    "includes": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "*.json",
      "!src/bindings/**",
      "!node_modules/**",
      "!dist/**"
    ]
  },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2 },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": { "noUnusedVariables": "error" },
      "style": {
        "noNonNullAssertion": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "framer-motion": {
                "message": "Import motion components from 'framer-motion/m' (m.div, m.button) under <LazyMotion features={domAnimation}>. The full 'motion' export pulls ~34 KB; LazyMotion + m is ~6 KB. AnimatePresence, LazyMotion, MotionConfig, domAnimation, and Variants from 'framer-motion' are still allowed.",
                "importNames": ["motion"]
              }
            }
          }
        }
      },
      "suspicious": { "noExplicitAny": "warn" }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "double", "semicolons": "always" } }
}
